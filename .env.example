# Copy to .env and fill in from your Supabase project settings.
# EXPO_PUBLIC_ vars are bundled into the client — safe here because the
# anon key is meant to be public and every table is protected by RLS
# (see supabase/migrations/0002_rls_policies.sql).
#
# NEVER put the service role key in an EXPO_PUBLIC_ var or any client code.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
